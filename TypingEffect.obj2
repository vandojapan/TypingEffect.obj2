    ["てぃ"]="thi", ["てゅ"]="thu", ["でぃ"]="dhi", ["でゅ"]="dhu",
    ["ぁ"]="xa", ["ぃ"]="xi", ["ぅ"]="xu", ["ぇ"]="xe", ["ぉ"]="xo",
    ["ゃ"]="xya", ["ゅ"]="xyu", ["ょ"]="xyo", ["ゎ"]="xwa",
    ["、"]=",", ["。"]=".", ["！"]="!", ["？"]="?", ["ー"]="-",
    [" "]=" ", ["　"]=" ", ["\n"]="\n"
