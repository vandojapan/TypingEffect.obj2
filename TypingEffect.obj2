--information:TypingEffect v0.5.4
--group:文章,true
--text@source:文章,今日はいい天気です
--select@language:言語,日本語=0,中文=1
--check@auto_analyze:自動解析,true
--track@typing_speed:入力速度,1,60,12,0.1
--track@conversion_wait:変換待ち,0,2000,350,10,待ちなし
--track@section_wait:文節間隔,0,2000,120,10,待ちなし
--group:書式,true
--font@font_name:フォント,メイリオ
--track@font_size:文字サイズ,8,500,72,1
--select@decoration:装飾,標準=0,影付き=1,影付き(薄)=2,縁取り=3,縁取り(細)=4,縁取り(太)=5,縁取り(角)=6
--color@text_color:文字色,0xffffff
--color@edge_color:影・縁色,0x000000
--check@bold:太字,false
--check@italic:斜体,false
--track@char_spacing:字間,-100,300,0,1
--track@line_spacing:行間,-100,300,0,1
--select@alignment:揃え,左揃え=0,中央揃え=1,右揃え=2
--group:カーソル,false
--check@show_cursor:カーソルを表示,true
--check@keep_cursor:完了後も表示,false
--track@cursor_blink_speed:速さ,0,15,1,0.01
--track@cursor_blink_ratio:点滅割合,0,100,50,1
--track@cursor_on_speed:点灯速度,0,100,100,1
--track@cursor_off_speed:消灯速度,0,100,75,1
--track@cursor_thickness:カーソルの太さ,1,100,3,1
--group:未確定文字,false
--check@show_underline:変換前に下線を表示,true
--track@underline_thickness:下線の太さ,1,12,2,1
--group

local function utf8_chars(value)
    local result = {}
    local i = 1
    while i <= #value do
        local b = string.byte(value, i)
        local size = 1
        if b >= 240 then
            size = 4
        elseif b >= 224 then
            size = 3
        elseif b >= 192 then
            size = 2
        end
        result[#result + 1] = string.sub(value, i, i + size - 1)
        i = i + size
    end
    return result
end

