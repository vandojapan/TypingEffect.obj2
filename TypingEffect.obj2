local prefixes = {}
for key, _ in pairs(romaji_kana) do
    for i = 1, #key - 1 do
        prefixes[string.sub(key, 1, i)] = true
    end
end
prefixes["n"] = true

local direct_keys = {
    [","]="、", ["."]="。", ["!"]="！", ["?"]="？",
    ["-"]="ー", [" "]="　", ["/"]="/", ["\n"]="\n"
}

local function is_consonant(ch)
    return string.find("bcdfghjklmnpqrstvwxyz", ch, 1, true) ~= nil
end

local function simulate_romaji(input)
    local states = {}
    local fixed = ""
    local pending = ""
    local keys = utf8_chars(string.lower(input or ""))

    for _, key in ipairs(keys) do
        if #key > 1 then
            if pending == "n" then
                fixed = fixed .. "ん"
                pending = ""
            elseif pending ~= "" then
                fixed = fixed .. pending
                pending = ""
            end
            fixed = fixed .. key
        elseif direct_keys[key] then
            if pending == "n" then
                fixed = fixed .. "ん"
            elseif pending ~= "" then
                fixed = fixed .. pending
            end
            pending = ""
            fixed = fixed .. direct_keys[key]
        else
            pending = pending .. key
            local resolving = true
            while resolving and pending ~= "" do
                resolving = false
                local first = string.sub(pending, 1, 1)
                local second = string.sub(pending, 2, 2)

                if #pending >= 2 and first == second and first ~= "n" and is_consonant(first) then
                    fixed = fixed .. "っ"
                    pending = string.sub(pending, 2)
                    resolving = true
                elseif string.sub(pending, 1, 2) == "n'" then
                    fixed = fixed .. "ん"
                    pending = string.sub(pending, 3)
                    resolving = true
                elseif #pending >= 2 and first == "n" and second == "n" then
                    fixed = fixed .. "ん"
                    pending = string.sub(pending, 2)
                    resolving = true
                elseif #pending >= 2 and first == "n" and is_consonant(second) and second ~= "y" then
                    fixed = fixed .. "ん"
                    pending = string.sub(pending, 2)
                    resolving = true
                elseif pending ~= "n" and romaji_kana[pending] then
                    fixed = fixed .. romaji_kana[pending]
                    pending = ""
                elseif prefixes[pending] then
                    -- 母音待ちの子音は英字のまま表示する。
                elseif #pending > 1 then
                    fixed = fixed .. first
                    pending = string.sub(pending, 2)
                    resolving = true
                end
            end
        end
        states[#states + 1] = fixed .. pending
    end

    if pending == "n" then
        fixed = fixed .. "ん"
    elseif pending ~= "" then
        fixed = fixed .. pending
    end
    if #states == 0 or states[#states] ~= fixed then
        states[#states + 1] = fixed
    end
    return states, fixed
end

local function simulate_literal_input(input)
    local states = {}
    local current = ""
    for _, key in ipairs(utf8_chars(input or "")) do
        current = current .. key
        states[#states + 1] = current
    end
    return states, current
end

local kata_to_hira = {}
do
    local hira = utf8_chars("ぁあぃいぅうぇえぉおかがきぎくぐけげこござじずぜぞさしすせそただちぢっつづてでとどなにぬねのはばぱひびぴふぶぷへべぺほぼぽまみむめもゃやゅゆょよらりるれろゎわゐゑをんゔ")
    local kata = utf8_chars("ァアィイゥウェエォオカガキギクグケゲコゴザジズゼゾサシスセソタダチヂッツヅテデトドナニヌネノハバパヒビピフブプヘベペホボポマミムメモャヤュユョヨラリルレロヮワヰヱヲンヴ")
    for i = 1, math.min(#hira, #kata) do
        kata_to_hira[kata[i]] = hira[i]
    end
end

local kana_romaji = {
    ["あ"]="a", ["い"]="i", ["う"]="u", ["え"]="e", ["お"]="o",
    ["か"]="ka", ["き"]="ki", ["く"]="ku", ["け"]="ke", ["こ"]="ko",
    ["が"]="ga", ["ぎ"]="gi", ["ぐ"]="gu", ["げ"]="ge", ["ご"]="go",
    ["さ"]="sa", ["し"]="shi", ["す"]="su", ["せ"]="se", ["そ"]="so",
    ["ざ"]="za", ["じ"]="ji", ["ず"]="zu", ["ぜ"]="ze", ["ぞ"]="zo",
    ["た"]="ta", ["ち"]="chi", ["つ"]="tsu", ["て"]="te", ["と"]="to",
    ["だ"]="da", ["ぢ"]="di", ["づ"]="du", ["で"]="de", ["ど"]="do",
    ["な"]="na", ["に"]="ni", ["ぬ"]="nu", ["ね"]="ne", ["の"]="no",
    ["は"]="ha", ["ひ"]="hi", ["ふ"]="fu", ["へ"]="he", ["ほ"]="ho",
    ["ば"]="ba", ["び"]="bi", ["ぶ"]="bu", ["べ"]="be", ["ぼ"]="bo",
    ["ぱ"]="pa", ["ぴ"]="pi", ["ぷ"]="pu", ["ぺ"]="pe", ["ぽ"]="po",
    ["ま"]="ma", ["み"]="mi", ["む"]="mu", ["め"]="me", ["も"]="mo",
    ["や"]="ya", ["ゆ"]="yu", ["よ"]="yo",
    ["ら"]="ra", ["り"]="ri", ["る"]="ru", ["れ"]="re", ["ろ"]="ro",
    ["わ"]="wa", ["ゐ"]="wi", ["ゑ"]="we", ["を"]="wo", ["ゔ"]="vu",
    ["きゃ"]="kya", ["きゅ"]="kyu", ["きょ"]="kyo",
    ["ぎゃ"]="gya", ["ぎゅ"]="gyu", ["ぎょ"]="gyo",
    ["しゃ"]="sha", ["しゅ"]="shu", ["しょ"]="sho",
    ["じゃ"]="ja", ["じゅ"]="ju", ["じょ"]="jo",
    ["ちゃ"]="cha", ["ちゅ"]="chu", ["ちょ"]="cho",
    ["にゃ"]="nya", ["にゅ"]="nyu", ["にょ"]="nyo",
    ["ひゃ"]="hya", ["ひゅ"]="hyu", ["ひょ"]="hyo",
    ["びゃ"]="bya", ["びゅ"]="byu", ["びょ"]="byo",
    ["ぴゃ"]="pya", ["ぴゅ"]="pyu", ["ぴょ"]="pyo",
